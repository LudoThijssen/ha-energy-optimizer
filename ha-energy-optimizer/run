#!/usr/bin/bashio
set -e

bashio::log.info "Starting HA Energy Optimizer v0.1.0-alpha..."

# Write configuration to options.json
# Schrijf configuratie naar options.json
bashio::config > /data/options.json
bashio::log.info "Configuration written to /data/options.json"

# Validate required settings / Valideer vereiste instellingen
if ! bashio::config.has_value "database.host"; then
    bashio::log.fatal "Database host not configured / Database host niet ingesteld"
    exit 1
fi

if ! bashio::config.has_value "homeassistant.token"; then
    bashio::log.fatal "HA token not configured / HA token niet ingesteld"
    exit 1
fi

bashio::log.info "Configuration OK / Configuratie OK"

# Start GUI in background / Start GUI op de achtergrond
bashio::log.info "Starting configuration GUI on port 8099..."
cd /app
python3 -m flask --app gui/app.py run \
    --host 0.0.0.0 \
    --port 8099 \
    --no-debugger &

# Start main optimizer / Start de optimizer
bashio::log.info "Starting optimizer engine / Optimizer-engine starten..."
exec python3 main.py
